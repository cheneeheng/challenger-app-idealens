# PostgreSQL async DSN (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://idealens:idealens@localhost:5432/idealens

# Secret for signing JWT access tokens
JWT_SECRET=change-me-to-a-long-random-string

# Fernet key for encrypting Anthropic API keys at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_KEY_ENCRYPTION_KEY=change-me-fernet-key

# development | production
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins
FRONTEND_URLS=http://localhost:3000

# Number of recent messages kept verbatim before summarization kicks in
CONTEXT_WINDOW_MAX_MESSAGES=20
